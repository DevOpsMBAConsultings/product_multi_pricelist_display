<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_pricelist_view_form_display" model="ir.ui.view">
        <field name="name">product.pricelist.form.display</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view"/>
        <field name="arch" type="xml">
            <group name="pricelist_settings" position="after">
                <group name="display_settings">
                    <field name="display_in_product_list"/>
                </group>
            </group>
        </field>
    </record>
</odoo>
